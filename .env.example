# 네이버 검색광고 키워드도구 API 키 (NaverAdapter 용)
# 실제 키는 https://manage.searchad.naver.com → 도구 > API 사용 관리 에서 발급.
# 이 파일(.env.example)은 템플릿이며 깃에 커밋해도 된다.
# 실제 값은 .env 에 넣고, .env 는 .gitignore 로 커밋 금지.
#
# 발급 항목 ↔ 환경변수 매핑:
#   액세스 라이선스(Access License) → NAVER_AD_API_KEY
#   비밀키(Secret Key)             → NAVER_AD_SECRET_KEY
#   고객 ID(CUSTOMER_ID)           → NAVER_AD_CUSTOMER_ID

NAVER_AD_API_KEY=
NAVER_AD_SECRET_KEY=
NAVER_AD_CUSTOMER_ID=

# 네이버 데이터랩(검색어트렌드) API 키 (scripts/diagnose_seasonal.py 용)
# 위 검색광고 키와 '다른' 인증 체계. https://developers.naver.com 에서
# 애플리케이션 등록 → 사용 API 에 '데이터랩(검색어트렌드)' 추가 후 발급.
#   Client ID     → NAVER_CLIENT_ID
#   Client Secret → NAVER_CLIENT_SECRET
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# 조견표(구글시트) ID — 체험단 '조견표 차종' 모드용. 시트 URL 의 /d/<여기>/edit 부분.
# 시트 ID 는 비밀이 아니나(접근은 서비스계정 공유로 통제) Public repo 노출 최소화 위해 .env 에 둔다.
# Streamlit Cloud 에선 st.secrets['jogyeonpyo_sheet_id'] 로 설정.
# ★서비스계정 private key(gcp_service_account)는 절대 .env/깃 금지 — st.secrets 또는 로컬 파일만.
JOGYEONPYO_SHEET_ID=
