# 네이버 검색광고 키워드도구 API 키 (NaverAdapter 용)
# 실제 키는 https://manage.searchad.naver.com → 도구 > API 사용 관리 에서 발급.
# 이 파일(.env.example)은 템플릿이며 깃에 커밋해도 된다.
# 실제 값은 .env 에 넣고, .env 는 .gitignore 로 커밋 금지.
#
# 발급 항목 ↔ 환경변수 매핑:
#   액세스 라이선스(Access License) → NAVER_AD_API_KEY
#   비밀키(Secret Key)             → NAVER_AD_SECRET_KEY
#   고객 ID(CUSTOMER_ID)           → NAVER_AD_CUSTOMER_ID

NAVER_AD_API_KEY=
NAVER_AD_SECRET_KEY=
NAVER_AD_CUSTOMER_ID=
